{
	"hooks": {
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && npx tsx src/collect.ts",
						"timeout": 10
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "SendMessage",
				"hooks": [
					{
						"type": "command",
						"command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && npx tsx src/gate.ts",
						"timeout": 10
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "SendMessage",
				"hooks": [
					{
						"type": "command",
						"command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && npx tsx src/gate.ts --post",
						"timeout": 10
					}
				]
			}
		]
	}
}
